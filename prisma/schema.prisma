  summary                           String                              @db.Text
  publisher                         String?                             @db.VarChar(50)
  author                            String?                             @db.VarChar(50)
  original_file                     String?                             @db.VarChar(512)
  ai_model_version                  String?                             @db.VarChar(50)
  create_time                       DateTime?                           @default(now()) @db.DateTime(0)
  update_time                       DateTime?                           @default(now()) @updatedAt @db.DateTime(0)
  original_url                      String?                             @db.VarChar(512)
  report_time                       DateTime?                           @db.DateTime(0)
  relation__board_industry_analysis relation__board_industry_analysis[]

  @@index([create_time], map: "idx_create_time")
}

